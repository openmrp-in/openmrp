---
import Base from '../../layouts/Base.astro'
import ProductGrid from '../../components/ProductGrid.astro'
import { productsByBrand } from '../../lib/api'

const { slug = '' } = Astro.params
const products = await productsByBrand(slug)
if (products.length === 0) Astro.response.status = 404
const brandName = products[0]?.brand || slug
---

<Base
  title={`${brandName} — OpenMRP`}
  description={`${brandName} products on OpenMRP — pack sizes and MRP. Free, open product data for India.`}
  canonical={`https://openmrp.in/brand/${slug}`}
>
  <h1>{brandName}</h1>
  {
    products.length === 0 ? (
      <p class="empty">No products for this brand yet.</p>
    ) : (
      <ProductGrid products={products} />
    )
  }
</Base>
