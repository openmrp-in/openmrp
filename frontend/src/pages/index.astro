---
import Base from '../layouts/Base.astro'

const title = 'OpenMRP — free, open product data for India'
const description =
  'Search a product or barcode to see its name, brand, pack size and real MRP. Free, open, community-built. The OpenFoodFacts of India.'
---

<Base title={title} description={description} canonical="https://openmrp.in/">
  <div style="text-align:center; padding: 48px 0;">
    <h1 style="font-size:34px;">Know the real MRP.</h1>
    <p style="color:#555; font-size:17px; margin:0 0 28px;">
      Free, open product data for India — search a name or enter a barcode.
    </p>
    <form class="search" action="/search" method="get" style="max-width:460px; margin:0 auto;">
      <input
        name="q"
        autocomplete="off"
        placeholder="Search a product, or a barcode…"
        aria-label="Search products or barcode"
        required
      />
      <button type="submit">Search</button>
    </form>
    <p style="margin-top:24px; color:#999; font-size:13px;">
      Community-built · ODbL open data · 22 Indian languages · <a href="/brands" style="color:#0a7d3c;">browse brands</a>
    </p>
  </div>
</Base>
