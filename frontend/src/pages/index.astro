---
import Base from '../layouts/Base.astro'

const title = 'OpenMRP — free, open product data for India'
const description =
  'Search a product or barcode to see its name, brand, pack size and real MRP. Free, open, community-built. The OpenFoodFacts of India.'
---

<Base title={title} description={description} canonical="https://openmrp.in/">
  <section class="hero" aria-labelledby="hero-title">
    <p class="eyebrow">Open product intelligence for India</p>
    <h1 id="hero-title">Know the real MRP before you buy.</h1>
    <p class="lead">
      Search a barcode or product name to discover brand details, pack size, food marks, multilingual names,
      and community-verified pricing from permitted sources.
    </p>
    <form class="search" action="/search" method="get" style="max-width:560px; margin:0 auto;">
      <input
        name="q"
        autocomplete="off"
        placeholder="Search a product, or scan a barcode…"
        aria-label="Search products or barcode"
        required
      />
      <button type="submit">Search</button>
    </form>
    <div class="hero-meta" aria-label="OpenMRP highlights">
      <span>Community-built</span>
      <span>ODbL open data</span>
      <span>22 Indian languages</span>
      <a href="/brands">Browse brands</a>
    </div>
    <div class="stat-strip" aria-label="OpenMRP capabilities">
      <div class="stat-card">
        <strong>₹ MRP</strong>
        <span>Pack-level price facts</span>
      </div>
      <div class="stat-card">
        <strong>22</strong>
        <span>Official Indian languages</span>
      </div>
      <div class="stat-card">
        <strong>Open</strong>
        <span>Data dumps and public API</span>
      </div>
    </div>
  </section>
</Base>
