{
  "name": "@openmrp/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "OpenMRP backend API — Cloudflare Workers + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply openmrp --local",
    "db:migrate:remote": "wrangler d1 migrations apply openmrp --remote",
    "db:seed-dev-key": "wrangler d1 execute openmrp --local --file=scripts/seed-dev-key.sql",
    "seed": "tsx scripts/seed.ts",
    "load-nppa": "tsx scripts/load-nppa.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.10.20",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20240821.0",
    "@vitest/coverage-istanbul": "^3.2.0",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "~3.2.0",
    "wrangler": "^4.0.0"
  }
}
